{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Airtable - Sheet Port",
  "version": "0.3.0",
  "identifier": "dev.sheetport.app",
  "build": {
    "beforeDevCommand": "pnpm stage:sidecar && pnpm dev",
    "devUrl": "http://127.0.0.1:8477",
    "beforeBuildCommand": "pnpm stage:sidecar && pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Airtable - Sheet Port",
        "width": 1180,
        "height": 760,
        "minWidth": 960,
        "minHeight": 640,
        "decorations": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "externalBin": ["binaries/sheet-port-mcp"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://raw.githubusercontent.com/h1dr0nn/airtable-sheet-port/main/updater.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IENEMjUxRkMzNTJGRUMxNkMKUldSc3dmNVN3eDhselpsZ2hTT0RabHFESXpORmhTRjdLWHZkTVZBdVd4Y3B0V0lsU2laczFPRDEK"
    }
  }
}
