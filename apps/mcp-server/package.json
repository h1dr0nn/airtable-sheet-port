{
  "name": "@sheet-port/mcp-server",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "sheet-port-mcp": "./dist/index.js"
  },
  "scripts": {
    "dev": "tsx --conditions development src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test:e2e": "node scripts/e2e-smoke.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.17.0",
    "@sheet-port/core": "workspace:*",
    "@sheet-port/mock-connector": "workspace:*",
    "@sheet-port/shared": "workspace:*",
    "@sheet-port/storage": "workspace:*",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
